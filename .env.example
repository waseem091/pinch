# Get a free testnet account + HBAR at https://portal.hedera.com
# Click "Create Testnet Account" — it gives you account ID + private key

# Your Hedera testnet operator account (pays to create robot wallets)
HEDERA_ACCOUNT_ID=0.0.XXXXXXX
HEDERA_PRIVATE_KEY=your-ecdsa-private-key-hex

# Created automatically on first run — paste the logged value here to reuse
BOUNTY_TOPIC_ID=

# Tuning (optional)
STUCK_THRESHOLD_MS=8000      # ms of no hands before robot is "stuck"
BOUNTY_AMOUNT_HBAR=0.5       # HBAR the robot pays per bounty
ROBOT_INITIAL_HBAR=5         # HBAR funded into each new robot wallet

# Override the relay (default: Cloudflare Worker)
# RELAY_WS=wss://pinch-relay.jenil-panchal10.workers.dev/ws

# ENS Robot Identity (Sepolia testnet)
# 1. Register a name free at https://app.ens.domains (switch to Sepolia network)
# 2. Get free Sepolia ETH at https://sepoliafaucet.com
# 3. Run: npm run ens:setup
ENS_PARENT_NAME=your-name.eth
ENS_PRIVATE_KEY=0x...   # wallet that owns the parent ENS name on Sepolia
