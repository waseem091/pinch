{
  "version": 2,
  "name": "pinch",
  "builds": [
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/bounties",    "dest": "/frontend/bounties.html" },
    { "src": "/xr",         "dest": "/frontend/xr.html" },
    { "src": "/xr.html",    "dest": "/frontend/xr.html" },
    { "src": "/assets/(.*)", "dest": "/frontend/assets/$1" },
    { "src": "/(.*)",        "dest": "/frontend/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Permissions-Policy", "value": "xr-spatial-tracking=*" }
      ]
    }
  ]
}
