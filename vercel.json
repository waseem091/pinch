{
  "version": 2,
  "name": "pinch",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/bounties(.*)", "dest": "/bounties/index.html" },
    { "src": "/(.*)",         "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Permissions-Policy", "value": "xr-spatial-tracking=*" }
      ]
    }
  ]
}
